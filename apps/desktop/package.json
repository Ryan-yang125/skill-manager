{
  "name": "@skill-manager/desktop",
  "version": "0.6.0",
  "private": true,
  "description": "Local-first desktop app for managing agent skills.",
  "author": "Yangrui <Ryan-yang125@users.noreply.github.com>",
  "homepage": "https://github.com/Ryan-yang125/skill-manager",
  "desktopName": "skill-manager",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm build && electron dist-electron/main.js",
    "frontend": "vite --host 127.0.0.1 --port 5173",
    "start": "pnpm build && electron dist-electron/main.js",
    "build": "pnpm --filter @skill-manager/core build && tsc -p electron/tsconfig.json && esbuild electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload.cjs && tsc -p tsconfig.json --noEmit && vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "pnpm --filter @skill-manager/core build && tsc -p electron/tsconfig.json --noEmit && tsc -p tsconfig.json --noEmit",
    "package": "pnpm build && node ../../scripts/package-mac.mjs",
    "package:mac": "pnpm build && node ../../scripts/package-mac.mjs",
    "package:win": "pnpm build && node ../../scripts/package-win.mjs",
    "package:linux": "pnpm build && node ../../scripts/package-linux.mjs"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@skill-manager/core": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.4",
    "lucide-react": "^0.562.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.1",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "build": {
    "appId": "com.yangrui.skillmanager",
    "productName": "Skill Manager",
    "executableName": "Skill Manager",
    "artifactName": "SkillManager-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "afterSign": "electron/after-sign.cjs",
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "../../dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Ryan-yang125",
        "repo": "skill-manager"
      }
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip",
        "dir"
      ]
    },
    "dmg": {
      "artifactName": "SkillManager-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "SkillManager-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "maintainer": "Yangrui <Ryan-yang125@users.noreply.github.com>",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "artifactName": "SkillManager-${version}-${arch}.${ext}"
    }
  }
}
